# LegacyLens – copy to .env and fill as needed

# Codebase to ingest (for pipeline)
# CODE_ROOT=./gnucobol-3.2_win
# CODE_EXTENSIONS=.cob,.cbl
# MAX_FILES=50  # limit files indexed (omit = no limit)
# Use * to ingest all file extensions:
# CODE_EXTENSIONS=*
# Skip very large files during discovery (default 2 MB)
# MAX_FILE_SIZE_MB=2
# Only ingest text-readable files (recommended for full-repo indexing)
# INGEST_TEXT_ONLY=true

# Qdrant: leave unset for local .qdrant_data/; set for Qdrant Cloud
# QDRANT_URL=https://xxx.qdrant.io
# QDRANT_API_KEY=your-api-key
# QDRANT_COLLECTION=legacylens-chunks

# Google Vertex AI (embeddings). If unset, pseudo-embeddings are used for dev.
# GOOGLE_CLOUD_PROJECT=your-gcp-project
# GOOGLE_CLOUD_LOCATION=us-central1

# Optional
# EMBED_BATCH_SIZE=100
# EMBEDDINGS_CACHE_PATH=embeddings.json
# EMBED_METADATA_PREFIX=true
# FALLBACK_CHUNK_LINES=45
# FALLBACK_OVERLAP_LINES=0

# Retrieval
# QUERY_TOP_K=50  # candidate pool for retrieval; keep 30+ for good coverage (10=too few)
# QUERY_FINAL_K=25  # chunks for /query endpoint
# QUERY_CHAT_FINAL_K=8  # chunks for chat; fewer = less context
# QUERY_CHAT_MAX_CHUNKS_PER_FILE=2  # cap chunks per file (rank by file, then best N per file); 0 = no cap
# CHAT_SNIPPET_MAX_LINES=20  # max lines per chunk in prompt/sources (0=no truncation)
# QUERY_SCORE_THRESHOLD=0.0
# MIN_VECTOR_SCORE=0.15  # drop results with vec score below this (filters junk)
# BM25_MIN_SCORE=1e-9  # filters BM25 zero-score noise (set higher for stricter lexical matches)
# USE_HYBRID_SEARCH=true
# USE_RERANKER=false  # set true for better quality; false for ~10s faster (no rerank)
# RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L6-v2  # fast; BAAI/bge-reranker-base for quality
# RRF_K=60

# Optional LLM for integrated chat (requires GOOGLE_CLOUD_PROJECT)
# LLM_MODEL=gemini-1.5-flash
# LLM_ENABLED=false

# Admin / management
# ADMIN_TOKEN=change-me-for-admin-endpoints
